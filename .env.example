# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# Deployment URL for generated links (e.g. invites)
# If left empty, window.location.origin will be used
VITE_APP_URL=

# Firebase web app config for project number 88050491406.
# These are safe client-side Firebase config values, but keep one source of truth in deployment env vars.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=gen-lang-client-0683642806.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0683642806
VITE_FIREBASE_STORAGE_BUCKET=gen-lang-client-0683642806.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=88050491406
VITE_FIREBASE_APP_ID=1:88050491406:web:06b09933cb2bf769b91c5f
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore database ID. Your Firebase project uses a named Firestore database,
# not "(default)", so the app must point to it explicitly.
VITE_FIRESTORE_DATABASE_ID=ai-studio-96491054-260f-4ee7-b4d2-c73b2a6faa0f

# Optional: enables automatic workspace invite emails.
# Create a Resend API key at https://resend.com/api-keys and use a verified sender/domain.
# Without this, the app creates the invite and opens a prefilled email draft instead.
RESEND_API_KEY=
RESEND_FROM_EMAIL="FlowState <onboarding@yourdomain.com>"

# Stripe subscriptions for paid analytics.
# Mainframe Analytics is $2.99/month. Workspace Analytics is tiered:
# $4.99/month for 1-15 employees, $5.99/month for 16-30 employees,
# then +$1/month for every additional 15 employees.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MAINFRAME_PRICE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=

# Firebase Admin credentials let the Stripe webhook unlock paid access in Firestore.
# Easiest local setup: download the Firebase service account JSON and save it as
# firebase-admin-service-account.json in this app folder. The file is git-ignored.
FIREBASE_SERVICE_ACCOUNT_FILE=firebase-admin-service-account.json

# Or use either FIREBASE_SERVICE_ACCOUNT_KEY as the full JSON service account string,
# FIREBASE_SERVICE_ACCOUNT_BASE64 as Base64-encoded JSON, or the split
# FIREBASE_PROJECT_ID/FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY values.
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
